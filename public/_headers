# Static assets - immutable hashed filenames, cache aggressively
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# Fonts
/*.woff2
  Cache-Control: public, max-age=31536000, immutable

# Images and icons
/*.ico
  Cache-Control: public, max-age=86400
/*.svg
  Cache-Control: public, max-age=86400

# HTML pages - short cache with revalidation
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Default for all other paths
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  # geolocation=(self) permits the qibla compass to read the user's
  # location when they tap "Use my location". An empty allowlist
  # blocks geolocation for the site itself as well as third parties,
  # which silently fails the qibla flow even when the OS grants
  # permission.
  Permissions-Policy: camera=(), microphone=(), geolocation=(self), usb=(), payment=()
  # Content-Security-Policy intentionally omitted - needs report-only
  # pass against the live bundle to confirm every allowed host before
  # re-enabling. Clickjacking is already covered by X-Frame-Options:
  # DENY above; XSS surface is small because we don't accept HTML
  # input anywhere. Post-hackathon follow-up.
