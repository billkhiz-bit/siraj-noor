# Production build defaults — committed, contains no secrets.
# These are public URLs baked into the JS bundle at build time by Next.js.
#
# NEXT_PUBLIC_QF_CLIENT_ID is intentionally NOT set here — it belongs in
# .env.production.local (gitignored) or as a shell export at deploy time.

NEXT_PUBLIC_QF_AUTH_HOST=https://oauth2.quran.foundation
NEXT_PUBLIC_QF_API_HOST=https://apis.quran.foundation
