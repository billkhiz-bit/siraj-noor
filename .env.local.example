# Quran Foundation API client - register at https://api-docs.quran.foundation/request-access
# The client_id is public (visible in auth redirect URLs) so NEXT_PUBLIC_ prefix is safe.
# NEVER put a client_secret in a NEXT_PUBLIC_ var - use PKCE public client flow only.
NEXT_PUBLIC_QF_CLIENT_ID=

# Optional - override default hosts. Defaults target the prelive sandbox for local dev.
# Production on Cloudflare Pages should set these to the prod hosts:
#   NEXT_PUBLIC_QF_AUTH_HOST=https://oauth2.quran.foundation
#   NEXT_PUBLIC_QF_API_HOST=https://apis.quran.foundation
NEXT_PUBLIC_QF_AUTH_HOST=https://prelive-oauth2.quran.foundation
NEXT_PUBLIC_QF_API_HOST=https://apis.quran.foundation
